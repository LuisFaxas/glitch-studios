# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=glitch-studios
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Site URL (for sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://glitchstudios.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
RESEND_API_KEY=re_...

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Booking System
CRON_SECRET=generate-a-random-32-char-string
STUDIO_TIMEZONE=America/New_York

# Phase 26 — Social Login (OAuth)
# Google OAuth (live at v4.0 launch on both brand hosts)
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URIs: https://glitchstudios.io/api/auth/callback/google
#                https://www.glitchstudios.io/api/auth/callback/google
#                https://glitchtech.io/api/auth/callback/google
#                https://www.glitchtech.io/api/auth/callback/google
#                http://localhost:3004/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta / Facebook OAuth (env stub — button hidden until vars set; covers FB + IG)
# Console: https://developers.facebook.com/apps/
# NOTE: Better Auth provider key is `facebook` even though env var is META_*
META_CLIENT_ID=
META_CLIENT_SECRET=

# GitHub OAuth (env stub — button hidden until vars set)
# Console: https://github.com/settings/developers
# Pitfall: GitHub OAuth Apps support ONE callback URL per app — register
# against glitchstudios.io and rely on Better Auth trustedOrigins for cross-host.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Phase 26 — Admin notification destination for new artist applications
# (falls back to a hard-coded studio inbox if unset)
ADMIN_NOTIFICATION_EMAIL=
